---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---<?xml version="1.0" encoding="utf-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ metadata.title }}</title>
    <link>{{ metadata.url }}</link>
    <description>{{ metadata.description }}</description>
    <atom:link href="{{ '/feed.xml' | absoluteUrl(metadata.url) }}" rel="self" type="application/rss+xml"/>
    <language>en</language>
    {%- set lastPost = collections.post | last %}
    {%- if lastPost %}
    <lastBuildDate>{{ lastPost.date | rssDate }}</lastBuildDate>
    {%- endif %}
    {%- for post in collections.post | reverse %}
    <item>
      <title>{{ post.data.title }}</title>
      <link>{{ post.url | absoluteUrl(metadata.url) }}</link>
      <description><![CDATA[{{ post.templateContent | safe }}]]></description>
      <pubDate>{{ post.date | rssDate }}</pubDate>
      <guid>{{ post.url | absoluteUrl(metadata.url) }}</guid>
    </item>
    {%- endfor %}
  </channel>
</rss>
