---
layout: "base.njk"
title: "Blog"
---
<section id="blog">
    <h2>Blog</h2>
    {% if collections.post.length %}
        <ul>
            {%- for post in collections.post | reverse -%}
                <li>
                    <a href="{{ post.url }}">
                        {{ post.data.title }} - <small>{{ post.date | readableDate }}</small>
                    </a>
                </li>
            {%- endfor -%}
        </ul>
    {% else %}
        <p>No blog posts yet. Please check back soon!</p>
    {% endif %}
</section>
